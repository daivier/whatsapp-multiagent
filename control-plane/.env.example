# Control plane — copiar para .env (NUNCA commitar o .env real)
PORT=4500
DB_PATH=/home/daivier/wa-control/signups.sqlite

# Mercado Pago (produção: APP_USR-... | testes: TEST-...)
MP_ACCESS_TOKEN=APP_USR-xxxxxxxx

# Pagamento: ASSINATURA recorrente por cartão (preapproval), checkout hospedado.
# WEBHOOK_URL é onde o MP notifica (reforço; o /status já faz polling).
WEBHOOK_URL=https://atendize.com/api/webhook
# Para onde o MP redireciona após autorizar o cartão (default: https://<ZONE>/?assinatura=ok)
# MP_BACK_URL=https://atendize.com/?assinatura=ok
# LANDING_URL=https://atendize.com

# Chave para aceder a GET /signups (gera uma aleatória forte)
ADMIN_KEY=troca-por-uma-chave-aleatoria

# Email de boas-vindas ao cliente (Fase 3b). Se SMTP_USER/SMTP_PASS faltarem,
# o email é ignorado e usa-se só o link wa.me (no log + /signups).
# Gmail: cria uma "palavra-passe de app" em https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=daivier@gmail.com
SMTP_PASS=app-password-de-16-letras
MAIL_FROM=Atendize <daivier@gmail.com>

# Provisionamento automático (Fase 3b) — opcional, têm defaults sensatos
# AUTO_PROVISION=1
# ZONE=atendize.com
# PORT_BASE=3031
# REPO_DIR=/home/daivier/whatsapp-multiagent
# TENANTS_DIR=/home/daivier/whatsapp-tenants
